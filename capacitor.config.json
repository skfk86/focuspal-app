{
  "appId": "com.focuspal.app",
  "appName": "FocusPal Pro",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "api.groq.com",
      "fonts.googleapis.com",
      "fonts.gstatic.com",
      "cdnjs.cloudflare.com"
    ]
  },
  "plugins": {
    "LocalNotifications": {},
    "SplashScreen": {
      "launchShowDuration": 800,
      "backgroundColor": "#0a0b0f",
      "androidSplashResourceName": "splash"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0b0f"
    }
  }
}
